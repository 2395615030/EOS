# === EmotionOS .gitignore ===

# 编译输出
*.exe
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.dylib
build/

# IDE/编辑器
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# 系统生成
Thumbs.db
.DS_Store

# NEFS 映像
nefs.img

# 临时日志/输出
*.log

# 测试输出 txt
tests/*.txt

# 原型构建
prototypes/**/*.exe
prototypes/**/*.o

# Git
.git/

# 本地配置
*.local

# 旧 kernel/ 目录（已迁移到 src/ + include/）
kernel/*.exe
kernel/*.txt
kernel/*.log
kernel/nefs.img
